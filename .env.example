# Optional search providers. Use at least one for full web discovery.
# Recommended first choices: BRAVE_API_KEY or SERPAPI_API_KEY.
SERPAPI_API_KEY=
BRAVE_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=
EXA_API_KEY=

# Optional no-key exploratory search. This requires installing optional tools:
# python3 -m pip install --target .vendor_eval -r requirements-optional.txt
DDGS_ENABLED=0

# Optional runtime settings.
FINDER_CACHE_DIR=.cache
FINDER_HTTP_TIMEOUT=12
FINDER_TAVILY_RAW_CONTENT=markdown
FINDER_SECOND_PASS_MAX_FETCH_CANDIDATES=6
FINDER_SECOND_PASS_RESCUE_FETCH_CANDIDATES=10
FINDER_SECOND_PASS_EXA_QUERIES=3

# Maintainer-only Development Workflow LLM agents. Normal Workflow Body does not need this.
OPENAI_API_KEY=
FINDER_DEV_AGENT_MODEL=gpt-4.1-mini
